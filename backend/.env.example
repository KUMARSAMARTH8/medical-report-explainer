# Copy this file to `.env` in the backend/ folder and adjust as needed.
# `.env` itself is gitignored — never commit real secrets or production values.

# --- App ---
APP_NAME="AI Medical Report Explainer"
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Use "*" for local development only. In production, list exact origins:
# CORS_ORIGINS=https://myapp.com,https://www.myapp.com
CORS_ORIGINS=*

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.bmp,.tiff
REPORTS_DIR=reports
DELETE_FILES_AFTER_PROCESSING=true

# --- Database ---
DB_PATH=reports.db

# --- Optional NLP upgrades ---
# Set to true only if you've installed sentence-transformers (see requirements.txt)
ENABLE_SEMANTIC_CHATBOT=false

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30
